\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Requirement 3 comparison against the best fixed feasible policy in hindsight. The dynamic optimum is reported to quantify the price of non-stationarity.}}{11}{table.caption.11}\protected@file@percent }
