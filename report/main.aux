\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Representative Requirement 3 regret curves. The primal-dual learner remains competitive both in a highly non-stationary regime and in the reused stationary stochastic regime.}}{12}{figure.caption.13}\protected@file@percent }
\newlabel{fig:req3-regret}{{7}{12}{Representative Requirement 3 regret curves. The primal-dual learner remains competitive both in a highly non-stationary regime and in the reused stationary stochastic regime}{figure.caption.13}{}}
